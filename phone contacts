contacts = {} #for storing contacts
#adding new contact
def add_contact(name:str, mobile:int):
    if name not in contacts:
        contacts[name] = mobile
        return "contact saved"
    return "contact name already exists, chesk with another name"

#update contact
def update_contact(name:str, mobile:int): 
    if name in contacts:
        contacts[name] = mobile
        return "contact saved"
    return "contact name not exists, check name again"

#delete contact
def delete_contact(name:str):
    if name in contacts:
        contacts.pop(name)
        return "contact deleted..."
    return "contact name not exists, check again..."

#get mobile number by searching name
def get_mobile_number(name:str):
    if name in contacts:
        return contacts[name]
    return "the number is received..."

#all contacts
def all_contacts():
    return contacts    

